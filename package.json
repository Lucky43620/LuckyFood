{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "ci": "composer run ci:backend && npm run ci:frontend",
        "ci:frontend": "npm audit --omit=dev && npm run lint && npm run format:check && npm run test:unit -- --run && npm run build",
        "dev": "vite",
        "format": "prettier --write \"resources/js/**/*.{js,vue}\" \"tests/{js,e2e}/**/*.js\" \"*.{js,json}\"",
        "format:check": "prettier --check \"resources/js/**/*.{js,vue}\" \"tests/{js,e2e}/**/*.js\" \"*.{js,json}\"",
        "lint": "eslint \"resources/js/**/*.{js,vue}\" \"tests/{js,e2e}/**/*.js\"",
        "lint:fix": "eslint \"resources/js/**/*.{js,vue}\" \"tests/{js,e2e}/**/*.js\" --fix",
        "test:e2e": "playwright test",
        "test:unit": "vitest"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@inertiajs/vue3": "^2.0",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.10",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vue/test-utils": "^2.4.10",
        "autoprefixer": "^10.4.16",
        "concurrently": "^9.0.1",
        "eslint": "^10.3.0",
        "eslint-plugin-vue": "^10.9.1",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.0.0",
        "postcss": "^8.4.32",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^3.4.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.5",
        "vue": "^3.3.13"
    },
    "dependencies": {
        "@zxing/browser": "^0.2.0",
        "axios": "^1.16.0",
        "lucide-vue-next": "^1.0.0"
    }
}
